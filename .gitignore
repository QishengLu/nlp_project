# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
.coverage
htmlcov/

# Data — produced trajectories never pushed.
# Drop trajectory experiments under data/trajectories/<exp_id>/<bug_id>/;
# the directory is auto-ignored so generated data (often 100MB+) never
# accidentally ends up in the repo. Datasets are distributed as tarballs
# (see README "Producing / sharing trajectories").
scratch/
*.log
*.tar.gz
data/trajectories/*
!data/trajectories/README.md
data/trajectories/*/*/raw/

# Env
.env

# Vendored deps (JDK 8, defects4j, Perl modules, cpanm) — large + reproducible
# via scripts/bootstrap_vendor.sh
vendor/
