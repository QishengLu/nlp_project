htmlcov/

# Data — checked-in fixed trajectories live under data/trajectories/<exp>/<bug>/.
# Block the bulk dirs (raw subprocess logs, failed runs we don't ship) but
# allow trajectories explicitly committed under data/trajectories/.
scratch/
*.log
data/trajectories/*/*/raw/

# Env
.env

# Vendored deps (JDK 8, defects4j, Perl modules, cpanm) — large + reproducible
# via scripts/bootstrap_vendor.sh
vendor/
